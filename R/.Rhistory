danny_params$vars$MC2_pH <- 0
danny_params$vars$W_Hyd_is <- 1
x <- seq(from = 0.01, to = 0.6, length.out = 51)
danny_params$graphs$W_PTheta$xy_data$W_PTheta1$x_val <- x
danny_params$graphs$W_PTheta$xy_data$W_PTheta2$x_val <- x
danny_params$graphs$W_PTheta$xy_data$W_PTheta3$x_val <- x
danny_params$graphs$W_PTheta$xy_data$W_PTheta4$x_val <- x
danny_params$graphs$W_PhiTheta$xy_data$W_PhiTheta1$x_val <- x
danny_params$graphs$W_PhiTheta$xy_data$W_PhiTheta2$x_val <- x
danny_params$graphs$W_PhiTheta$xy_data$W_PhiTheta3$x_val <- x
danny_params$graphs$W_PhiTheta$xy_data$W_PhiTheta4$x_val <- x
